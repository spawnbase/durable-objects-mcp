{
  "name": "durable-objects-mcp",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "wrangler types && tsc --noEmit",
    "cf-typegen": "wrangler types",
    "deploy": "wrangler deploy",
    "dev": "wrangler dev",
    "lint": "oxlint --fix",
    "prepare": "husky",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write",
      "oxlint --fix"
    ],
    "*.{json,md,yaml,yml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@cloudflare/workers-oauth-provider": "0.3.2",
    "@modelcontextprotocol/sdk": "1.29.0",
    "agents": "0.9.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "0.13.5",
    "@types/node": "22.15.3",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxlint": "^1.57.0",
    "prettier": "^3.8.1",
    "typescript": "5.9.3",
    "vitest": "4.1.2",
    "wrangler": "4.78.0"
  },
  "packageManager": "pnpm@10.33.0"
}
